# ЮMoney OAuth настройки
YMONEY_CLIENT_ID=your_client_id_here
YMONEY_CLIENT_SECRET=your_client_secret_here
YMONEY_WALLET_NUMBER=410011234567890
YMONEY_REDIRECT_URI=http://your-domain.com:5000/yoomoney_redirect
YMONEY_WEBHOOK_SECRET=your_webhook_secret_here

# Telegram Bot Token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Настройки сервера
PORT=5000
DEBUG=False

# Путь к базе данных
DB_PATH=db.sqlite

# Настройки админ-панели
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

