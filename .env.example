# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# ID администратора (ваш Telegram ID)
ADMIN_ID=2018301997

# Если бот и AmneziaWG крутятся на одном VPS, укажите публичный IP или домен,
# который будет попадать в Endpoint клиентского конфига.
SERVER_HOST=72.56.52.7
SERVER_USER=root
SERVER_SSH_KEY=~/.ssh/id_ed25519

# Путь к базе данных (внутри проекта)
DATABASE_PATH=database.db

# Путь для хранения выданных конфигов/QR
VPN_CONFIGS_DIR=vpn_configs

# Контакты (если используются)
CONTACTS_FILE=contacts.json

# AmneziaWG / WireGuard settings
VPN_PROTOCOL=amneziawg
VPN_PORT=44415
VPN_NETWORK=10.8.1.0/24
VPN_DOCKER_CONTAINER=amnezia-awg
VPN_INTERFACE=wg0

# MTProxy: если бот/веб-админка на том же сервере, что и прокси — ставить 1 (не нужен SSH ключ)
# MTPROXY_USE_LOCAL=1

# Web/admin (опционально)
WEB_SERVER_DOMAIN=72.56.52.7
WEB_SERVER_PORT=8888
